# Telegram bot credentials (get token from @BotFather, chat id from @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# How often to check prices, in seconds (default 1 hour)
CHECK_INTERVAL=3600

# Notify when price drops at least this fraction below last seen price (0.05 = 5%)
PRICE_DROP_THRESHOLD=0.0

# SQLite database file
DB_PATH=priceparser.db
